<odoo>

    <!-- REQUEST LIST VIEW -->
    <record id="view_citizen_request_list" model="ir.ui.view">
        <field name="name">citizen.request.list</field>
        <field name="model">citizen.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="category_id"/>
                <field name="priority" widget="badge" decoration-success="priority == 'low'" decoration-danger="priority == 'high'" decoration-warning="priority == 'medium'"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- REQUEST FORM VIEW -->
    <record id="view_citizen_request_form" model="ir.ui.view">
        <field name="name">citizen.request.form</field>
        <field name="model">citizen.request</field>
        <field name="arch" type="xml">
            <form>
            <header>
                <button name="action_submit"
                        type="object"
                        string="Submit"
                        class="btn-primary"
                        invisible="status != 'draft'"/>

                <button name="action_mark_in_progress"
                        type="object"
                        string="Start Work"
                        class="btn-primary"
                        invisible="status != 'submitted'"/>

                <button name="action_mark_resolved"
                        type="object"
                        string="Resolve"
                        class="btn-success"
                        invisible="status != 'in_progress'"/>

                <field name="status" widget="statusbar"
                    statusbar_visible="draft,submitted,in_progress,resolved"/>
            </header>
                <sheet>
                    <group>
                        <field name="citizen_id"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="location"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                        <field name="request_date" readonly="1"/>
                        <field name="resolved_date" readonly="1"/>
                        <field name="status" readonly="1"/>
                        <field name="priority" readonly="1"/>
                        <field name="category_id"/>
                        <field name="ai_summary" readonly="1"/>
                    </group>
                    <group string="Feedback" name="feedback" invisible="status != 'resolved'">
                            <field name="rating" widget="priority"/>
                            <field name="feedback"/>
                            <button name="action_reopen" 
                                type="object" 
                                string="Reopen Case" 
                                class="btn-warning" 
                                confirm="Are you sure you want to reopen this request?"
                                invisible="status != 'resolved'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_citizen_request" model="ir.actions.act_window">
        <field name="name">Citizen Requests</field>
        <field name="res_model">citizen.request</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>