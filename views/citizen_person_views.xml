<odoo>

    <!-- CITIZEN LIST VIEW -->
    <record id="view_citizen_person_list" model="ir.ui.view">
        <field name="name">citizen.person.list</field>
        <field name="model">citizen.person</field>
        <field name="arch" type="xml">
        <list decoration-success="is_verified == True" decoration-danger="is_verified == False">
            <field name="name"/>
            <field name="national_id"/>
            <field name="dob"/>
            <field name="phone"/>
            <field name="is_verified" string="Status"/>
        </list>
    </field>
    </record>

    <!-- CITIZEN FORM VIEW -->

    <record id="view_citizen_person_form" model="ir.ui.view">
        <field name="name">citizen.person.form</field>
        <field name="model">citizen.person</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit_request" type="object" string="Submit Request" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="national_id"/>
                        <field name="dob"/>
                        <field name="phone"/>
                        <field name="is_verified" widget="boolean_toggle" readonly="1"/>
                    </group>
                    <notebook>
                    <page string="Requests">
                        <field name="request_ids">
                            <list>
                                <field name="name"/>
                                <field name="status"/>
                                <field name="priority"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <!-- CITIZEN KANBAN VIEW -->
    <record id="view_citizen_person_kanban" model="ir.ui.view">
        <field name="name">citizen.person.kanban</field>
        <field name="model">citizen.person</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="national_id"/>
                <field name="dob"/>
                <field name="phone"/>
                <field name="image"/>
                <field name="is_verified"/> 

                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record" style="border: none; box-shadow: none; background: transparent;">
                            <div class="o_kanban_primary_left" style="width: 80px; display: flex; align-items: center; justify-content: center;">
                                <img t-if="record.image.raw_value"
                                     t-att-src="'/web/image/citizen.person/' + record.id.raw_value + '/image'"
                                     class="oe_kanban_avatar"
                                     style="border-radius: 50%; width: 64px; height: 64px; object-fit: cover;"/>
                                <i t-else="" class="fa fa-user-circle fa-4x" style="color: #dee2e6;"/>
                            </div>

                            <div class="o_kanban_primary_right" style="padding-left: 12px;">
                                <strong class="o_kanban_record_title" style="font-size: 16px;">
                                    <field name="name"/>
                                </strong>
                                
                                <div class="text-muted">ID: <field name="national_id"/></div>
                                <div class="text-muted">DOB: <field name="dob"/></div>
                                <div class="text-muted">Phone: <field name="phone"/></div>

                                <div style="margin-top: 8px;">
                                    <span t-if="record.is_verified.raw_value" class="badge rounded-pill bg-success">
                                        <i class="fa fa-check-circle"/> Verified
                                    </span>
                                    <span t-else="" class="badge rounded-pill bg-danger">
                                        <i class="fa fa-times-circle"/> Not Verified
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_citizen_people" model="ir.actions.act_window">
        <field name="name">Citizens</field>
        <field name="res_model">citizen.person</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first citizen!
            </p>
        </field>
    </record>
</odoo>